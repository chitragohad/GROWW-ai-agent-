# Railway environment — pulse-api and pulse-worker services
# Mount a Volume at /data and set PULSE_DATA_DIR=/data

PULSE_ENV=production
PULSE_DATA_DIR=/data
HF_HOME=/data/hf-cache

# Groq summarization (required for full pipeline runs on worker)
GROQ_API_KEY=

# Hosted Google MCP (Chitra MCP on Railway)
MCP_SERVER_URL=https://web-production-bf583.up.railway.app
MCP_APPROVAL_KEY=

# Delivery targets
GOOGLE_DOC_ID=
PULSE_EMAIL_RECIPIENTS=ops@example.com

# pulse-api: draft | pulse-worker: send
PULSE_EMAIL_MODE=draft

# Worker only — required for production email send
# PULSE_PRODUCTION_CONFIRM=1

# Optional failure alerts
# PULSE_ALERT_WEBHOOK_URL=

# API CORS — comma-separated origins (Vercel production + previews)
# PULSE_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Railway sets PORT automatically for pulse-api
