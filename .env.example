# Pulse agent environment — copy to .env for local development
PULSE_ENV=development
PULSE_DATA_DIR=./data
MCP_CONFIG_PATH=./config/mcp/servers.json

# LLM provider (required for summarization from Phase 2 onward)
GROQ_API_KEY=

# Optional: Hugging Face model cache directory for BGE embeddings
# HF_HOME=./data/hf-cache

# Hosted Google MCP server (Phases 5–6)
# https://github.com/chitragohad/Chitra-MCP-server
MCP_SERVER_URL=https://web-production-bf583.up.railway.app
MCP_APPROVAL_KEY=
GOOGLE_DOC_ID=
PULSE_EMAIL_RECIPIENTS=

# Production go-live (Phase 9) — required for mode=send when PULSE_ENV=production
# PULSE_PRODUCTION_CONFIRM=1

# Optional failure alerts (Slack-compatible webhook)
# PULSE_ALERT_WEBHOOK_URL=

# Railway / Vercel deployment
# PULSE_API_PORT=8001
# PULSE_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Optional overrides
PULSE_EMAIL_MODE=draft
